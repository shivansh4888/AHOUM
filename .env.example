GROQ_API_KEY=gsk_replace_this_with_your_key
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant
SECONDARY_MODEL=llama-3.1-8b-instant
ROUTER_BACKEND=lexical
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://localhost:8080,http://127.0.0.1:8080
MAX_ROUTER_FACETS=300
SCORING_BATCH_SIZE=12
CONFIDENCE_ENSEMBLE_RUNS=2
LLM_SCORING_FACET_LIMIT=60
